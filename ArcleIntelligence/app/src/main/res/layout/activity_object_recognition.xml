<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/object_recognition_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0C">

    <!-- Camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Bounding box overlay -->
    <View
        android:id="@+id/overlay_canvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top bar overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="#AA0A0A0C"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="🔎 Object Recognition"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom detection count bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#AA0A0A0C"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:id="@+id/detection_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 objects detected"
            android:textColor="#6E56CF"
            android:textSize="16sp" />
    </LinearLayout>
</FrameLayout>
